<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>Batch <%= batch.id %> - Phone Backup Portal</title>
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body>
    <main class="container">
      <header class="topbar">
        <h1>Batch #<%= batch.id %></h1>
        <nav>
          <a class="button" href="/batches">All batches</a>
          <a
            class="button primary"
            href="/batches/<%= batch.id %>/download-zip"
            >Download all as ZIP</a
          >
        </nav>
      </header>

      <p class="muted">
        Uploaded at <%= new Date(batch.created_at).toLocaleString() %>
      </p>

      <% if (!files || files.length === 0) { %>
      <p>No files in this batch.</p>
      <% } else { %>
      <ul class="list">
        <% files.forEach(function (file) { %>
        <li class="card list-item">
          <div>
            <div class="title"><%= file.original_name %></div>
            <div class="muted">
              <%= (file.size_bytes / (1024 * 1024)).toFixed(2) %> MB •
              <%= new Date(file.created_at).toLocaleString() %>
            </div>
          </div>
          <a class="button" href="/files/<%= file.id %>/download">Download</a>
        </li>
        <% }); %>
      </ul>
      <% } %>
    </main>
  </body>
</html>

